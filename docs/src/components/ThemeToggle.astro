---
/**
 * Overrides Starlight's native <select> theme switcher with a single button that cycles
 * light → dark → system. "system" follows the OS `prefers-color-scheme` live.
 *
 * Persistence matches Starlight's own convention: store 'light'/'dark' under `starlight-theme`
 * for explicit choices, and REMOVE the key for system mode. Starlight's first-paint head script
 * resolves a stored value with `theme === 'light' ? 'light' : 'dark'` — so a literal 'auto' would
 * be read as dark. Leaving the key absent lets its `prefers-color-scheme` fallback run, so system
 * mode renders the real OS theme on first paint with no flash.
 */
---

<button type="button" class="theme-toggle" data-theme-toggle aria-label="Theme">
  <svg class="theme-toggle__sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
  </svg>
  <svg class="theme-toggle__moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
  <svg class="theme-toggle__auto" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="2" y="4" width="20" height="13" rx="2"></rect>
    <path d="M8 21h8M12 17v4"></path>
  </svg>
</button>

<script>
  const KEY = 'starlight-theme';
  const MODES = ['light', 'dark', 'auto'] as const;
  type Mode = (typeof MODES)[number];

  const media = window.matchMedia('(prefers-color-scheme: dark)');

  const currentMode = (): Mode => {
    const stored = localStorage.getItem(KEY);
    return stored === 'light' || stored === 'dark' ? stored : 'auto';
  };

  function resolve(mode: Mode): 'light' | 'dark' {
    if (mode === 'auto') return media.matches ? 'dark' : 'light';
    return mode;
  }

  function apply(mode: Mode) {
    try {
      // Absent key = system mode (Starlight's head script then resolves via prefers-color-scheme).
      if (mode === 'auto') localStorage.removeItem(KEY);
      else localStorage.setItem(KEY, mode);
    } catch {}
    document.documentElement.dataset.theme = resolve(mode);
    sync();
  }

  function sync() {
    const mode = currentMode();
    const label =
      mode === 'auto' ? 'Theme: system (click for light)'
      : mode === 'light' ? 'Theme: light (click for dark)'
      : 'Theme: dark (click for system)';
    document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((btn) => {
      btn.dataset.mode = mode;
      btn.setAttribute('aria-label', label);
    });
  }

  function init() {
    // Migrate the legacy literal 'auto' some users still have stored: older builds wrote it, and
    // Starlight's head script reads it as dark. Drop it so system mode resolves to the OS theme.
    if (localStorage.getItem(KEY) === 'auto') apply('auto');
    sync();
    document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((btn) => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = 'true';
      btn.addEventListener('click', () => {
        const next = MODES[(MODES.indexOf(currentMode()) + 1) % MODES.length];
        apply(next);
      });
    });
  }

  // Re-resolve when the OS preference flips, but only while in "system" mode.
  media.addEventListener('change', () => {
    if (currentMode() === 'auto') apply('auto');
  });

  init();
  document.addEventListener('astro:page-load', init);
</script>
