---
type Glyph = { glyph: string; tone: string; label: string; note?: string };

const status: Glyph[] = [
  { glyph: '◯', tone: 'dim', label: 'Queued', note: 'waiting for a worker slot' },
  { glyph: '⠋', tone: 'warn', label: 'Running', note: 'animated spinner while pulling' },
  { glyph: '◌', tone: 'muted', label: 'Up to date', note: 'already at the remote tip' },
  { glyph: '✓', tone: 'ok', label: 'Updated', note: 'fast-forwarded to new commits' },
  { glyph: '▽', tone: 'dim', label: 'No upstream', note: 'branch has no upstream: nothing to pull (not an error)' },
  { glyph: '◇', tone: 'dim', label: 'Skipped', note: 'dirty tree / not ff-able' },
  { glyph: '↯', tone: 'magenta', label: 'Throttled', note: 'remote rate-limited: concurrency drops, auto-retried with backoff' },
  { glyph: '✗', tone: 'err', label: 'Failed', note: 'the pull errored' },
  { glyph: '◌', tone: 'dim', label: 'Cached', note: 'last-known status from the cache, shown dim with an age until pulled' },
];

const columns: Glyph[] = [
  { glyph: 'ahead-behind', tone: 'mixed', label: 'Ahead / behind', note: 'key a · commits ahead (green) and behind (cyan) upstream' },
  { glyph: '•2', tone: 'err', label: 'Dirty', note: 'key d · uncommitted file count' },
  { glyph: '4d', tone: 'muted', label: 'Last commit', note: 'key l · relative age' },
  { glyph: '⑃2', tone: 'cyan', label: 'Worktrees', note: 'key w · linked worktree count' },
  { glyph: '⑂3', tone: 'ok', label: 'Branches', note: 'key b · local branches excluding main/dev' },
  { glyph: '≡1', tone: 'magenta', label: 'Stashes', note: 'key s · stash entry count' },
  { glyph: '⇣7', tone: 'ok', label: 'Pulled', note: 'key p · commits the last pull landed' },
  { glyph: '±12', tone: 'cyan', label: 'Changed', note: 'key c · files the last pull changed' },
  { glyph: '●', tone: 'err', label: 'Dirty marker', note: 'always-on: repo has uncommitted changes' },
];
---

<div class="legend">
  <div class="legend__group">
    <h3>Status glyphs</h3>
    <ul role="list">
      {
        status.map((item) => (
          <li>
            <span class={`legend__glyph legend__glyph--${item.tone}`}>{item.glyph}</span>
            <span class="legend__text">
              <strong>{item.label}</strong>
              {item.note && <em>{item.note}</em>}
            </span>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="legend__group">
    <h3>Column glyphs</h3>
    <ul role="list">
      {
        columns.map((item) => (
          <li>
            <span class={`legend__glyph legend__glyph--${item.tone}`}>
              {item.tone === 'mixed' ? (
                <>
                  <span class="g1">↑3</span>
                  <span class="g2">↓1</span>
                </>
              ) : (
                item.glyph
              )}
            </span>
            <span class="legend__text">
              <strong>{item.label}</strong>
              {item.note && <em>{item.note}</em>}
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</div>
