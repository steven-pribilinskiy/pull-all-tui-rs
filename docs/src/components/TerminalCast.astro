---
/**
 * A terminal "window" framing a real recorded polygit session, played by asciinema-player.
 * The frame is part of the brand: a mono title bar echoing the app's own `[1] polygit · …`
 * header. Two recordings exist — `<base>-light.cast` and `<base>-dark.cast` (polygit's own
 * light/dark palette) — and the player swaps to match the page theme. Plays on its own when
 * motion is allowed; shows a populated still + controls otherwise.
 */
interface Props {
  /** Base cast name under /public, WITHOUT the `-light`/`-dark` suffix or `.cast`. */
  src: string;
  /** Title-bar text — mirrors the app's pane title. */
  title?: string;
  /** Poster frame time in seconds (a populated frame, not the blank cold start). */
  poster?: number;
}
const { src, title = '[1] polygit', poster = 2.3 } = Astro.props;
const base = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/${src}`;
---

<figure class="termcast" data-termcast>
  <div class="termcast__bar" aria-hidden="true">
    <span class="termcast__dots"><i></i><i></i><i></i></span>
    <span class="termcast__title">{title}</span>
    <span class="termcast__hint">recorded session</span>
  </div>
  <div class="termcast__screen" data-termcast-screen data-base={base} data-poster={poster}></div>
  <figcaption class="sr-only">A recorded polygit session: discovering repos, pulling them in parallel, and opening the info panel.</figcaption>
</figure>

<script>
  import * as AsciinemaPlayer from 'asciinema-player';
  import 'asciinema-player/dist/bundle/asciinema-player.css';

  type Entry = { player: { dispose?: () => void }; theme: string };
  const players = new WeakMap<HTMLElement, Entry>();

  function currentTheme(): 'light' | 'dark' {
    return document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
  }

  function render(el: HTMLElement) {
    const theme = currentTheme();
    const existing = players.get(el);
    if (existing && existing.theme === theme) return;
    existing?.player.dispose?.();
    el.replaceChildren();

    const base = el.dataset.base!;
    const poster = Number(el.dataset.poster ?? 0);
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const player = AsciinemaPlayer.create(`${base}-${theme}.cast`, el, {
      autoPlay: !reduce,
      loop: !reduce,
      preload: true,
      controls: true,
      poster: `npt:${poster}`,
      idleTimeLimit: 1.4,
      terminalFontFamily:
        "ui-monospace, 'SF Mono', 'JetBrains Mono', 'Cascadia Code', Menlo, Consolas, monospace",
      fit: 'width',
    });
    players.set(el, { player, theme });
  }

  function init() {
    const screens = document.querySelectorAll<HTMLElement>('[data-termcast-screen]');
    screens.forEach((el) => {
      // Spin up the player only when it nears the viewport.
      const io = new IntersectionObserver(
        (entries, obs) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              render(entry.target as HTMLElement);
              obs.disconnect();
            }
          }
        },
        { rootMargin: '200px' }
      );
      io.observe(el);
    });

    // Re-render with the matching cast whenever the site theme flips.
    const themeObserver = new MutationObserver(() => {
      document
        .querySelectorAll<HTMLElement>('[data-termcast-screen]')
        .forEach((el) => {
          if (players.has(el)) render(el);
        });
    });
    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
